package com.future.blue.purchase.dao;

import java.util.List;
import java.util.Map;

import com.future.blue.purchase.vo.ChatVO;

public interface IChatDAO {
    // 채팅방 목록 조회
    List<ChatVO> selectChatList();

    // 채팅방 생성
    void createChatRoom(Map<String, Object> params);

    // 채팅 메시지 삽입
    void insertChatMessage(Map<String, Object> params);

    // 채팅방 상태 업데이트
    void updateChatRoomStatus(Map<String, Object> params);

}

